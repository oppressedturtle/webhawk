# WebHawk backend configuration. Copy to `.env` for local dev (gitignored).
# All variables are prefixed WEBHAWK_.

WEBHAWK_ENVIRONMENT=development
WEBHAWK_DEBUG=true
WEBHAWK_HOST=0.0.0.0
WEBHAWK_PORT=8000

# Comma-separated allowlist of dashboard origins.
WEBHAWK_CORS_ORIGINS=["http://localhost:5173"]

# Datastores (used from Phase 0 item 2 onward).
WEBHAWK_DATABASE_URL=postgresql+psycopg://webhawk:webhawk@localhost:5432/webhawk
WEBHAWK_REDIS_URL=redis://localhost:6379/0
